	"scripts": {
		"predev": "lsof -ti:2906 | xargs kill -9 2>/dev/null; true",
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && node scripts/build.js",
		"start": "node dist/index.js",
		"serve": "npm run build && npm run start",
		"lint": "eslint src --ext .ts,.tsx",
		"lint:fix": "eslint src --ext .ts,.tsx --fix",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"db:setup": "node scripts/db-setup.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:check": "drizzle-kit check",
		"db:status": "node scripts/db/status.js",
		"db:reset": "node scripts/db/reset.js",
		"db:test": "node scripts/db/check.js"
	},
