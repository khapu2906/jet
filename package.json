{
  "name": "api-server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.app.json && tsc-alias -p tsconfig.app.json",
    "dev": "tsx watch src/main.ts",
    "serve": "tsc -p tsconfig.app.json && tsc-alias -p tsconfig.app.json && node dist/apps/api-server/src/main.js",
    "start": "node dist/apps/api-server/src/main.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:setup": "node scripts/db-setup.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:status": "node scripts/db-status.js",
    "db:reset": "node scripts/reset-db.js",
    "db:test": "node scripts/test-db.js",
    "auth:login": "node scripts/get-user-token.js"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.962.0",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/client-ses": "^3.957.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@fire-shield/core": "^2.2.2",
    "@fire-shield/hono": "^2.1.1",
    "@hono/node-server": "^1.19.6",
    "@hono/standard-validator": "^0.1.5",
    "@hono/swagger-ui": "^0.5.2",
    "@khapu2906/treasure-chest": "^1.4.1",
    "@valibot/to-json-schema": "^1.3.0",
    "aws-jwt-verify": "^5.1.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.6",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.4",
    "hono-openapi": "^1.1.1",
    "jsonwebtoken": "^9.0.2",
    "meo-meo-logger": "^1.2.0",
    "openai": "^6.15.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.16.3",
    "pg-boss": "^12.5.4",
    "postgres": "3.4.5",
    "tslib": "^2.8.1",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@aws-amplify/auth": "^6.17.1",
    "@eslint/js": "^9.18.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.10",
    "aws-amplify": "^6.15.9",
    "eslint": "^9.18.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
