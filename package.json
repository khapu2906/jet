{
	"name": "api-server",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"predev": "lsof -ti:2906 | xargs kill -9 2>/dev/null; true",
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
		"start": "node dist/apps/api-server/src/index.js",
		"serve": "npm run build && npm run start",
		"lint": "eslint src --ext .ts,.tsx",
		"lint:fix": "eslint src --ext .ts,.tsx --fix",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"db:setup": "node scripts/db-setup.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:check": "drizzle-kit check",
		"db:status": "node scripts/db-status.js",
		"db:reset": "node scripts/reset-db.js",
		"db:test": "node scripts/test-db.js",
		"auth:login": "node scripts/get-user-token.js"
	},
	"dependencies": {
		"@fire-shield/core": "^2.2.2",
		"@fire-shield/hono": "^2.1.1",
		"@hono/node-server": "^1.19.11",
		"@hono/standard-validator": "^0.2.2",
		"@hono/swagger-ui": "^0.5.3",
		"@khapu2906/treasure-chest": "^1.4.1",
		"@standard-community/standard-json": "^0.3.5",
		"@standard-community/standard-openapi": "^0.2.9",
		"@valibot/to-json-schema": "^1.5.0",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.44.7",
		"hono": "^4.12.5",
		"hono-openapi": "^1.3.0",
		"hono-rate-limiter": "^0.5.3",
		"jsonwebtoken": "^9.0.3",
		"meo-meo-logger": "^1.2.0",
		"openapi-types": "^12.1.3",
		"pg": "^8.20.0",
		"pg-boss": "^12.14.0",
		"postgres": "3.4.5",
		"quansync": "^1.0.0",
		"tslib": "^2.8.1",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20.19.37",
		"@types/pg": "^8.18.0",
		"eslint": "^9.39.4",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	}
}
